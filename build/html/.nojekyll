name: Deploy Sphinx Docs

on:
  push:
    branches: [main]
  workflow_dispatch:  # allows manual trigger

jobs:
  deploy-docs:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout spatial-ecology.net
        uses: actions/checkout@v4

      - name: Checkout SE_docs
        uses: actions/checkout@v4
        with:
          repository: selvaje/SE_docs
          path: SE_docs_repo

      - name: Copy built HTML docs into docs/ folder
        run: |
          mkdir -p docs/build/html
          cp -r SE_docs_repo/build/html/. docs/build/html/
          touch docs/build/html/.nojekyll

      - name: Commit and push docs
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          git add docs/
          git diff --cached --quiet || git commit -m "Update Sphinx docs from SE_docs"
          git push